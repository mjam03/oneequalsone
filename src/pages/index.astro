---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 2em 1em;
			}
			h1 {
				font-size: 2.5rem;
				margin-bottom: 0.25em;
			}
			.tagline {
				font-size: 1.2rem;
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			.intro {
				font-size: 1.05rem;
				line-height: 1.7;
				margin-bottom: 2em;
			}
			.intro p {
				margin-bottom: 1em;
			}
			.topics {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6em;
				margin-bottom: 2.5em;
			}
			.topic {
				background: rgb(var(--gray-light));
				border-radius: 20px;
				padding: 0.3em 0.9em;
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
			}
			.cta {
				display: inline-block;
				background: var(--accent);
				color: white;
				padding: 0.6em 1.4em;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1rem;
				transition: opacity 0.2s ease;
			}
			.cta:hover {
				opacity: 0.85;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Mark.</h1>
			<p class="tagline">I write about quant finance, Python, tennis, and anything else I feel like over-engineering.</p>

			<div class="intro">
				<p>
					I work in finance and have a habit of going down rabbit holes — usually involving a Python notebook,
					a pile of statistics, and a question that seemed simple until it wasn't. This blog is where those
					rabbit holes get written up.
				</p>
				<p>
					The aim is always to explain things from first principles: no hand-waving, no assumed knowledge,
					just a patient walk through the reasoning with as many graphs as it takes. If you've ever wondered
					<em>why</em> we use log returns, or <em>why</em> tennis is scored the way it is, you're in the right place.
				</p>
			</div>

			<div class="topics">
				<span class="topic">Quantitative Finance</span>
				<span class="topic">Python</span>
				<span class="topic">Statistics</span>
				<span class="topic">Tennis Analytics</span>
				<span class="topic">Data Science</span>
				<span class="topic">Environmental Data</span>
			</div>

			<a href="/blog" class="cta">Read the blog</a>
		</main>
		<Footer />
	</body>
</html>
